# ==========================================
# TELEGRAM BOT CONFIGURATION
# ==========================================
BOT_TOKEN=your_telegram_bot_token_here
OWNER_ID=your_telegram_user_id_here

# ==========================================
# GOOGLE SHEETS CONFIGURATION
# ==========================================
# Path to your Google Service Account JSON file
GOOGLE_SERVICE_ACCOUNT_PATH=./google-service-account.json
# Default email to share every new sheet with
DEFAULT_SHARE_EMAIL=youremail@gmail.com

# ==========================================
# OPTIONAL: TWITTER API (for tweet verification)
# ==========================================
TWITTER_BEARER_TOKEN=optional_twitter_bearer_token
